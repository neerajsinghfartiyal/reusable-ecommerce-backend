PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce_cms

# Required — use a long random value in production (never commit real secrets)
JWT_SECRET=your_super_secret_key

NODE_ENV=development

# Optional — order notification emails (leave blank to skip email sends locally)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Reusable Store
SMTP_FROM_EMAIL=no-reply@example.com
ADMIN_NOTIFICATION_EMAIL=
